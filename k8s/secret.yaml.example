# secret.example.yaml — template only, values intentionally blank
#
# DO NOT commit real secrets to git.
# Create the actual secret with:
#
#   kubectl create secret generic rag-secrets \
#     --namespace rag \
#     --from-literal=ANTHROPIC_API_KEY=<value> \
#     --from-literal=OPENAI_API_KEY=<value> \
#     --from-literal=CHAINLIT_AUTH_SECRET=<value> \
#     --from-literal=ADMIN_SECRET=<value> \
#     --from-literal=OAUTH_GITHUB_CLIENT_ID=<value> \
#     --from-literal=OAUTH_GITHUB_CLIENT_SECRET=<value> \
#     --from-literal=PG_DATABASE_URL=<read-only-supabase-dsn>
#
# PG_DATABASE_URL is the read-only Supabase DSN (same DB as the Azure
# deployment). With a read-only role, keep DB_INIT_SCHEMA=false in the
# configmap — schema DDL is owned by the admin/ETL connection.
# See docs/supabase-readonly-role.md.
#
# To generate CHAINLIT_AUTH_SECRET:
#   uv run chainlit create-secret
# To generate ADMIN_SECRET:
#   openssl rand -hex 32
#
apiVersion: v1
kind: Secret
metadata:
  name: rag-secrets
  namespace: rag
type: Opaque
stringData:
  ANTHROPIC_API_KEY: ""
  OPENAI_API_KEY: ""
  CHAINLIT_AUTH_SECRET: ""
  ADMIN_SECRET: ""
  # GitHub OAuth App credentials (auth is OAuth-only). See docs/public-access-setup.md.
  OAUTH_GITHUB_CLIENT_ID: ""
  OAUTH_GITHUB_CLIENT_SECRET: ""
  # Read-only Supabase DSN, e.g. postgresql://USER:PASS@HOST:5432/postgres
  PG_DATABASE_URL: ""
