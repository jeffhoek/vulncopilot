# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
# NVD_API_KEY=your-nvd-api-key  # optional, increases NVD rate limit (https://nvd.nist.gov/developers/request-an-api-key)

# PostgreSQL Configuration
# Use PG_DATABASE_URL (not DATABASE_URL) to avoid Chainlit auto-activating its own data layer
# PG_DATABASE_URL=postgresql://postgresuser:postgrespw@localhost:5432/inventory
# Timescale Cloud (use PG_DATABASE_URL instead of individual PG_* vars)
# PG_DATABASE_URL=postgresql://user:password@hostname.tsdb.cloud.timescale.com:5432/dbname?sslmode=require
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgresuser
PG_PASSWORD=postgrespw
PG_DATABASE=inventory

# RAG Configuration (optional - these have defaults)
# TOP_K=5
# EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=anthropic:claude-haiku-4-5-20251001
#SYSTEM_PROMPT="You are a helpful assistant. Use the retrieve tool to find relevant context before answering questions. Answer the user's question helpfully and concisely based on the retrieved context. If the answer is not in the context, say you don't have that information."

# Action Buttons (optional — JSON array of quick-query button labels)
# ACTION_BUTTONS=["Show latest KEV additions","Critical vulns with active exploits","Which vendors appear most in KEV?","VPN and remote access vulnerabilities","Ransomware-linked vulnerabilities","Microsoft product vulnerabilities","Network device vulnerabilities","Vulnerabilities added to KEV in 2026","Show unpatched critical vulnerabilities","AI and cloud tool vulnerabilities","Which weakness types appear most in KEV?","Top CWE categories by average CVSS score","Show critical CVEs grouped by weakness type"]
# CWE-focused buttons (requires cwe_definitions table — run scripts/load_cwe.py first):
# ACTION_BUTTONS=["Which weakness types appear most in KEV?","Top CWE categories by average CVSS score","How many KEV entries involve injection weaknesses?","What is CWE-79 and which CVEs are affected?","Which vendors have the most memory corruption CVEs?","Show critical CVEs grouped by weakness type"]

# Authentication
APP_USERNAME=admin
APP_PASSWORD=your-password-here
CHAINLIT_AUTH_SECRET=generate-with-chainlit-create-secret

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_BASE_URL=http://langfuse-web:3000

# Logfire Observability
# LOGFIRE_ENABLED=true  # set to true to enable (uses LOGFIRE_TOKEN in production, local CLI auth in dev)
# LOGFIRE_TOKEN=your-logfire-token
