# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
# NVD_API_KEY=your-nvd-api-key  # optional, increases NVD rate limit (https://nvd.nist.gov/developers/request-an-api-key)

# PostgreSQL Configuration
# Use PG_DATABASE_URL (not DATABASE_URL) to avoid Chainlit auto-activating its own data layer
PG_DATABASE_URL=postgresql://postgresuser:postgrespw@localhost:5432/inventory
# Timescale Cloud (use PG_DATABASE_URL instead of individual PG_* vars)
# PG_DATABASE_URL=postgresql://user:password@hostname.tsdb.cloud.timescale.com:5432/dbname?sslmode=require

# Alternative: set the parts individually instead of PG_DATABASE_URL (used only when it is unset).
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgresuser
# PG_PASSWORD=postgrespw
# PG_DATABASE=inventory

# RAG Configuration (optional - these have defaults)
# TOP_K=5
# EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=anthropic:claude-haiku-4-5-20251001
# SYSTEM_PROMPT overrides the built-in prompt in config.py. The built-in prompt includes full
# database schema documentation (table names, columns, JOIN guidance) that the agent requires
# to generate correct SQL. If you override it, you must include that schema context or query
# quality will degrade significantly. See config.py for the current prompt to use as a base.
#SYSTEM_PROMPT="You are a helpful assistant. Use the retrieve tool to find relevant context before answering questions. Answer the user's question helpfully and concisely based on the retrieved context. If the answer is not in the context, say you don't have that information."

# Action Buttons (optional — JSON array of quick-query button labels)
# Full production set is in infra/modules/app-service.bicep and k8s/configmap.yaml.
# ACTION_BUTTONS=["Latest KEV additions","Ransomware-linked vulns","Critical vulns with active exploits","Anthropic Claude","CVE-2026-25253","OpenClaw","Reference URLs for CVE-2017-11882","Top AI vulns in 2026","VPN and remote access vulns","Network device vulns","Microsoft product vulns","Top vendors in KEV","Top CWE categories by avg CVSS score","CWE-78", "Log4j"]

# Authentication — GitHub OAuth
# Create an OAuth App at github.com/settings/developers (see docs/public-access-setup.md).
# Callback URL must be: https://your-domain/auth/oauth/github/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# Required for OAuth sessions — generate with: uv run chainlit create-secret
# Without it, OAuth sessions silently fail to persist on deploy.
CHAINLIT_AUTH_SECRET=generate-with-chainlit-create-secret
# OAuth — Google (future — requires oauth_callback changes, see docs; not wired up yet)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# Authorization
# NOTE: list values are parsed by pydantic-settings as JSON arrays, NOT comma-separated.
# A bare `a@x.com,b@y.com` raises SettingsError on startup. Use JSON, matching ACTION_BUTTONS.
OPEN_REGISTRATION=false
# ALLOWED_EMAILS=["alice@example.com","bob@example.com"]   (email addresses only)
# ALLOWED_LOGINS=["jeffhoek","alice"]                       (GitHub usernames only)
# ALLOWED_EMAIL_DOMAINS=["mycompany.com"]

# Rate Limiting — max queries per user per UTC day (counted in Postgres user_usage)
DAILY_QUERY_LIMIT=20
# Elevated cap for admins/trusted users, keyed by stable GitHub identifier.
# Listed identifiers get ADMIN_DAILY_QUERY_LIMIT instead of DAILY_QUERY_LIMIT.
# JSON array (like the allow-list vars). Find your id in the user_usage table.
ADMIN_DAILY_QUERY_LIMIT=100000
# ADMIN_USER_IDENTIFIERS=["github:12345678"]

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_BASE_URL=http://langfuse-web:3000

# Logfire Observability
# LOGFIRE_ENABLED=true  # set to true to enable (uses LOGFIRE_TOKEN in production, local CLI auth in dev)
# LOGFIRE_TOKEN=your-logfire-token
